# ─── DareFi Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# WalletConnect Project ID
# Create a free project at https://cloud.reown.com → "Create Project"
# Select "React Native" as the platform, then copy the Project ID.
WALLETCONNECT_PROJECT_ID=

# Starkzap API Key (optional – required only for gasless transactions / staking)
# Obtain from https://starkzap.io/dashboard
STARKZAP_API_KEY=
